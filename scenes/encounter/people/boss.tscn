[sub_resource type="GDScript" id="GDScript_iotei"]
script/source = "extends BulletSpawner

@export var eye1: Marker2D
@export var eye2: Marker2D
@export var mouth: Marker2D


func do(emotion: Topic.Emotion) -> void:
	Console.scan_max = 12 * 3
	var tex := Bullet.TEX_SPARKLE
	if emotion == Topic.Emotion.NERVOUS:
		tex = Bullet.TEX_DROPLET
	await get_tree().create_timer(0.5).timeout
	await spawn_circle(eye1.position, 12, tex, 0.05, 80)
	await get_tree().create_timer(0.5).timeout
	await spawn_circle(eye2.position + Vector2.RIGHT * 32, 12, tex, 0.05, 80)
	await get_tree().create_timer(0.5).timeout
	await spawn_circle(mouth.position + Vector2.LEFT * 32, 12, tex, 0.05, 80)
	done.emit()
"

[node name="Boss" unique_id=359469956 node_paths=PackedStringArray("animator", "bullet_spawner") instance=ExtResource("1_4lv0d")]
topics = Array[ExtResource("2_bjruo")]([SubResource("Resource_bjruo"), SubResource("Resource_0mxwg"), SubResource("Resource_iotei"), SubResource("Resource_ffpwu")])
goal_topic = SubResource("Resource_rl58q")
goal = 4.0
starting_lines = "Agent Gnortz... Terrans are known to communicate in completely incomprehensible ways.
Your mission requires you to interact with them and find out the whereabouts of Ni-Cola Tesla. He might be hiding himself.
This is why we have equipped you with the latest [color=red]social signal[/color] interpreting tech.
Let's familiarise you with it... When one exhibits an [color=blue]emotional response[/color], use your [color=blue]tech device[/color] to collect bits of info.
These disappear quick and move around wildly, so expertise is required.
With enough [color=blue]info[/color], the machine can determine what conversation topics are optimal to continue.
Let's try it out. Pick a conversation topic."
ending_lines = "You win!!! hahahahahahahprepare_topics"
emotion_response_animations = Dictionary[int, StringName]({
1: &"smile",
4: &"nervous"
})
animator = NodePath("Animator")
bullet_spawner = NodePath("BulletSpawner")

