[sub_resource type="Resource" id="Resource_ioo8f"]
script = ExtResource("2_m71ut")
name = "TalkAboutScience"
responses = PackedStringArray("This lab here? Yeah I`m quite a scientist myself, of course none of these moron`s here see that.\nNo matter though, soon I will make it big with my investments and finance my own projects.")
