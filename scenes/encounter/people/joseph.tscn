[sub_resource type="Resource" id="Resource_tim23"]
script = ExtResource("2_m71ut")
name = "TalkAboutReligion"
responses = PackedStringArray("God? Have you talked to Mary or something? She always loved to discuss god and religion. \nAbsolute nonsense if you ask me, no self-respecting intellectual person follows any religion.\n Bunch of morons man, Marys dad was the worst.\n")
contribution_to_goal = -1.0
