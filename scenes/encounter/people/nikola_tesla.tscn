[sub_resource type="GDScript" id="GDScript_kpdy8"]
script/source = "extends BulletSpawner

@export var eye1: Marker2D
@export var eye2: Marker2D
@export var mouth: Marker2D

var progress := 0


func do(emotion: Topic.Emotion) -> void:

	var tex := Bullet.TEX_SPARK

	match progress:
		0:
			Console.scan_max = int(12 * 3 * 1.5)
			await wait_t(0.5)
			await spawn_circle(eye1.global_position, 12, tex, 0.05, 80)
			await wait_t(0.5)
			await spawn_circle(eye2.global_position + Vector2.RIGHT * 32, 12, tex, 0.05, 80)
			await wait_t(0.5)
			await spawn_circle(mouth.global_position + Vector2.LEFT * 32, 12, tex, 0.05, 80)
		1:
			Console.scan_max = int((40 + 40) * 1.5)
			for i in 40:
				var b := Bullet.make(mouth.global_position + Vector2(rand2(), rand2()) * 120)
				b.set_direction(Vector2.DOWN, rand2() + 80.0)
				b.set_texture(tex)
				b.max_lifetime = 3.0
				add_child(b)
				await wait_t(0.03)
			spawn_circle(eye1.global_position, 40, tex, 0.01, 80)
		2:
			var i := 0
			Console.scan_max = int(12 * 12 * 12 * 1.5)
			for x: float in range(-6, 7):
				for y: float in range(-6, 7):
					spawn_circle(Vector2(x / 12 * 720 + sin(y), y / 12 * 480 + cos(x)) * 0.75, 12, tex, maxf(0.1 - i * 0.001, 0.001), 110)
			await wait_t(0.8)
		3:
			Console.scan_max = int(10 * 120 * 1.25)
			for y in range(-5, 5):
				for x in range(-60, 60):
					var b := Bullet.make(Vector2(float(x) / 120 * 720, sin(x) * y * 240))
					b.set_texture(tex)
					b.set_direction(Vector2.DOWN if x % 2 == 0 else Vector2.UP, 80)
					b.max_lifetime = 3.0
					b.drag = -0.05
					add_child(b)
			await wait_t(4.0)
		4:
			Console.scan_max = 120
			for i in range(-60, 60):
				var b := Bullet.make(Vector2(i * 5, sin(i) * 120))
				b.set_direction(Vector2(sin(b.position.x), cos(b.position.y)), 120.0)
				b.set_texture(tex)
				add_child(b)
				await wait_t(0.05)
		5:
			Console.scan_max = int(10 * 24 * 0.75)
			for y in range(-5, 5):
				for x in range(-12, 12):
					var b := Bullet.make(Vector2(float(x) / 24 * 480, sin(x) * y * 240))
					b.set_direction(Vector2.DOWN if x % 2 == 0 else Vector2.UP, 80)
					b.set_texture(tex)
					b.max_lifetime = 3.0
					b.drag = -0.05
					add_child(b)
			await wait_t(2.0)
		6:
			await spawn_crazy_shape(120)

	progress = clampi(progress + 1, 0, 6)

	await wait_t(0.5)
	done.emit()
"

